# Copy this file to .env and fill in your Cloudflare Workers AI credentials.
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
# Cloudflare Workers AI API token. CLOUDFLARE_API_TOKEN is also accepted as an alias.
CLOUDFLARE_AUTH_TOKEN=your_cloudflare_workers_ai_api_token

# Optional: override the default Workers AI vision model.
# WORKERS_AI_MODEL=@cf/meta/llama-4-scout-17b-16e-instruct
